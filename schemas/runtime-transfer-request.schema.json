{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/runtime-transfer-request.schema.json",
  "title": "runtime.transfer.request",
  "description": "Runtime-originated request to deliver a generated artifact to the App.",
  "type": "object",
  "required": ["type", "protocol_version", "payload"],
  "properties": {
    "type": { "const": "runtime.transfer.request" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "required": ["transfer_id", "artifact_id", "filename", "mime_type", "size_bytes", "download_url", "sha256"],
      "properties": {
        "transfer_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10485760
        },
        "download_url": {
          "type": "string",
          "pattern": "^https://.+"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "description": {
          "type": "string"
        },
        "source_runtime_id": {
          "type": "string",
          "minLength": 1
        },
        "source_message_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "const": "runtime_to_app"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
