{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/runtime-transfer-completed.schema.json",
  "title": "runtime.transfer.completed",
  "description": "App acknowledgement that a Runtime-originated generated artifact was downloaded and validated.",
  "type": "object",
  "required": ["type", "protocol_version", "payload"],
  "properties": {
    "type": { "const": "runtime.transfer.completed" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "required": ["transfer_id", "artifact_id", "size_bytes", "sha256"],
      "properties": {
        "transfer_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10485760
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_runtime_id": {
          "type": "string",
          "minLength": 1
        },
        "source_message_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
