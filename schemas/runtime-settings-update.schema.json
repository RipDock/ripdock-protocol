{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/runtime-settings-update.schema.json",
  "title": "runtime.settings.update",
  "description": "App-originated Runtime settings update or action request.",
  "type": "object",
  "required": ["type", "protocol_version", "runtime_id"],
  "properties": {
    "type": { "const": "runtime.settings.update" },
    "protocol_version": { "const": "1" },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "settings": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9_.:-]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/setting_value"
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9_.:-]+$"
      },
      "uniqueItems": true
    }
  },
  "anyOf": [
    { "required": ["settings"] },
    { "required": ["actions"] }
  ],
  "$defs": {
    "setting_value": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string" },
        { "type": "number" },
        { "type": "null" }
      ]
    }
  },
  "additionalProperties": false
}
