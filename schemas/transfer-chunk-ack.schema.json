{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/transfer-chunk-ack.schema.json",
  "title": "transfer.chunk.ack",
  "description": "Transfer channel acknowledgement that one upload chunk was fully received and written.",
  "type": "object",
  "required": ["type", "protocol_version", "conversation_id", "payload"],
  "properties": {
    "type": { "const": "transfer.chunk.ack" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "required": ["transfer_id", "received_bytes"],
      "properties": {
        "transfer_id": {
          "type": "string",
          "minLength": 1
        },
        "received_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10485760
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
