{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/message-delta.schema.json",
  "title": "message.delta",
  "type": "object",
  "required": ["type", "protocol_version", "delta"],
  "properties": {
    "type": { "const": "message.delta" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "delta": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
