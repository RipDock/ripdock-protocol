{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/runtime-slash-commands.schema.json",
  "title": "runtime.slash_commands",
  "description": "Runtime-advertised slash command definitions. Commands are Runtime-owned chat commands; the App owns presentation and sends selected commands as normal message.create content.",
  "type": "object",
  "required": ["type", "protocol_version", "runtime_id", "commands"],
  "properties": {
    "type": { "const": "runtime.slash_commands" },
    "protocol_version": { "const": "1" },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slash_command"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "slash_command": {
      "type": "object",
      "required": ["name", "display", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$"
        },
        "display": {
          "type": "string",
          "minLength": 2,
          "pattern": "^/[A-Za-z0-9_.:-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "argument_hint": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
