{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/message-create.schema.json",
  "title": "message.create",
  "type": "object",
  "required": ["type", "protocol_version", "runtime_id", "agent_id", "conversation_id", "client_message_id", "content"],
  "properties": {
    "type": { "const": "message.create" },
    "protocol_version": { "const": "1" },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "client_message_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "transfer_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "maxItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
