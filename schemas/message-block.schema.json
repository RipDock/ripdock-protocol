{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/message-block.schema.json",
  "title": "message.block",
  "description": "Semantic content block event. The Runtime declares semantic intent; the App owns visual presentation.",
  "type": "object",
  "required": ["type", "protocol_version", "block"],
  "properties": {
    "type": { "const": "message.block" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "block": {
      "$ref": "#/$defs/block"
    }
  },
  "$defs": {
    "block": {
      "type": "object",
      "required": ["kind", "mime_type", "content"],
      "properties": {
        "kind": {
          "enum": [
            "text",
            "markdown",
            "code",
            "log",
            "data",
            "activity.status",
            "activity.plan",
            "activity.notice",
            "activity.tool.call",
            "activity.tool.progress",
            "activity.tool.result",
            "activity.tool.error",
            "activity.tool.retry",
            "activity.file.search",
            "activity.file.resolve",
            "activity.artifact.register",
            "activity.code.run",
            "activity.model.info",
            "artifact.reference"
          ]
        },
        "mime_type": {
          "enum": [
            "text/plain",
            "text/markdown",
            "text/code",
            "text/log",
            "application/json",
            "application/yaml",
            "application/vnd.ripdock.activity+json",
            "application/vnd.ripdock.artifact+json"
          ]
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string"
        },
        "copyable": {
          "type": "boolean"
        },
        "wrap": {
          "type": "boolean"
        },
        "collapsed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
