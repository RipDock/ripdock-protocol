{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/transfer-ready.schema.json",
  "title": "transfer.ready",
  "description": "Endpoint approval and transfer channel location for a requested file transfer.",
  "type": "object",
  "required": ["type", "protocol_version", "conversation_id", "payload"],
  "properties": {
    "type": { "const": "transfer.ready" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "required": ["transfer_id", "transfer_url", "max_file_bytes", "max_chunk_bytes"],
      "properties": {
        "transfer_id": {
          "type": "string",
          "minLength": 1
        },
        "transfer_url": {
          "type": "string",
          "pattern": "^wss://.+"
        },
        "max_file_bytes": {
          "type": "integer",
          "const": 10485760
        },
        "max_chunk_bytes": {
          "type": "integer",
          "const": 1048576
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
