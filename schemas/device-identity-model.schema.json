{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/device-identity-model.schema.json",
  "title": "DeviceIdentity",
  "description": "Stable cryptographic identity for one RIPDOCK App Device.",
  "type": "object",
  "required": [
    "deviceId",
    "deviceName",
    "publicKey",
    "publicKeyFingerprint",
    "createdAt"
  ],
  "properties": {
    "deviceId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "deviceName": {
      "type": "string",
      "minLength": 1
    },
    "publicKey": {
      "$ref": "./p256-jwk-public-key.schema.json"
    },
    "publicKeyFingerprint": {
      "description": "MUST equal publicKey.key_id.",
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  },
  "additionalProperties": false
}
