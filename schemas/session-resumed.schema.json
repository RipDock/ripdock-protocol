{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/session-resumed.schema.json",
  "title": "session.resumed",
  "description": "Acknowledgement that a durable Session was resumed on the current WebSocket connection.",
  "type": "object",
  "required": ["type", "protocol_version", "session_id"],
  "properties": {
    "type": { "const": "session.resumed" },
    "protocol_version": { "const": "1" },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "app_device_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "resumed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "payload": {
      "type": "object",
      "properties": {
        "authorization_scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
