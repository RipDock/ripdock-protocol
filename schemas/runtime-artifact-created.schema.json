{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ripdock.org/schemas/runtime-artifact-created.schema.json",
  "title": "runtime.artifact.created",
  "description": "Runtime-generated artifact metadata event. The Runtime declares an artifact that can be attached to an assistant message and delivered to the App.",
  "type": "object",
  "required": ["type", "protocol_version", "artifact_id", "filename", "mime_type", "size_bytes"],
  "properties": {
    "type": { "const": "runtime.artifact.created" },
    "protocol_version": { "const": "1" },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "transfer_id": {
      "type": "string",
      "minLength": 1
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "mime_type": {
      "type": "string",
      "minLength": 1
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10485760
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "description": {
      "type": "string"
    },
    "source_runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "source_message_id": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "download_url": {
      "type": "string",
      "pattern": "^https://.+"
    },
    "expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["artifact_id", "filename", "mime_type", "size_bytes"],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "transfer_id": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10485760
        },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "description": {
          "type": "string"
        },
        "source_runtime_id": {
          "type": "string",
          "minLength": 1
        },
        "source_message_id": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "download_url": {
          "type": "string",
          "pattern": "^https://.+"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
